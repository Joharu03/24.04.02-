<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fluid Particle Texture Effect</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background-color: #0b0b0b;
            overflow: hidden;
            width: 100vw;
            height: 100vh;
            cursor: grab;
        }
        body:active {
            cursor: grabbing;
        }
        canvas {
            display: block;
            width: 100%;
            height: 100%;
        }
    </style>
</head>
<body>

    <canvas id="particleCanvas"></canvas>

    <script>
        const canvas = document.getElementById('particleCanvas');
        const ctx = canvas.getContext('2d');

        // 
        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        // 
        const mouse = {
            x: null,
            y: null,
            px: null, // 
            py: null, // 
            vx: 0,    // 
            vy: 0,    // 
            isDragging: false
        };

        const settings = {
            particleCount: 1200,      // 
            particleRadius: 2.5,     // 
            mouseRadius: 100,        // 
            forceFactor: 0.15,       // 
            viscosity: 0.94,         // 
            spring: 0.02             // 
        };

        const particles = [];

        // 
        class Particle {
            constructor(x, y) {
                this.baseX = x; //
                this.baseY = y;
                this.x = x;     //
                this.y = y;
                this.vx = 0;    // 
                this.vy = 0;
            }

            update() {
                // 
                let dxBase = this.baseX - this.x;
                let dyBase = this.baseY - this.y;
                this.vx += dxBase * settings.spring;
                this.vy += dyBase * settings.spring;

                // 
                if (mouse.x !== null && mouse.isDragging) {
                    let dxMouse = this.x - mouse.x;
                    let dyMouse = this.y - mouse.y;
                    let distance = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);

                    if (distance < settings.mouseRadius) {
                        // 
                        let force = (settings.mouseRadius - distance) / settings.mouseRadius;
                        
                        // 
                        this.vx += (dxMouse / distance) * force * settings.forceFactor * 15;
                        this.vy += (dyMouse / distance) * force * settings.forceFactor * 15;
                        
                        //
                        this.vx += mouse.vx * force * 0.2;
                        this.vy += mouse.vy * force * 0.2;
                    }
                }

                //
                this.vx *= settings.viscosity;
                this.vy *= settings.viscosity;
                this.x += this.vx;
                this.y += this.vy;
            }

            draw() {
                // 
                ctx.beginPath();
                ctx.arc(this.x, this.y, settings.particleRadius, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(240, 240, 245, 0.85)';
                ctx.fill();
            }
        }

        // 
        function init() {
            particles.length = 0;
            // í™”ë©´ ì „ì²´ì— ì´˜ì´˜í•˜ê²Œ ë°°ì¹˜í•˜ê¸° ìœ„í•´ ê°„ê²© ê³„ì‚°
            const cols = Math.floor(Math.sqrt(settings.particleCount * (canvas.width / canvas.height)));
            const rows = Math.floor(settings.particleCount / cols);
            
            const spacingX = canvas.width / (cols + 1);
            const spacingY = canvas.height / (rows + 1);

            for (let i = 0; i < cols; i++) {
                for (let j = 0; j < rows; j++) {
                    let x = spacingX + i * spacingX + (Math.random() * 4 - 2); // ë¯¸ì„¸í•œ ë¬´ìž‘ìœ„ì„± ë¶€ì—¬
                    let y = spacingY + j * spacingY + (Math.random() * 4 - 2);
                    particles.push(new Particle(x, y));
                }
            }
        }

        // 
        function animate() {
            // 
            ctx.fillStyle = 'rgba(11, 11, 11, 0.35)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // 
            if (mouse.px !== null && mouse.py !== null && mouse.x !== null) {
                mouse.vx = mouse.x - mouse.px;
                mouse.vy = mouse.y - mouse.py;
            }
            mouse.px = mouse.x;
            mouse.py = mouse.y;

            // 
            mouse.vx *= 0.8;
            mouse.vy *= 0.8;

            //
            particles.forEach(particle => {
                particle.update();
                particle.draw();
            });

            requestAnimationFrame(animate);
        }

        
        window.addEventListener('mousedown', (e) => {
            mouse.isDragging = true;
            mouse.x = e.clientX;
            mouse.y = e.clientY;
            mouse.px = e.clientX;
            mouse.py = e.clientY;
        });

        window.addEventListener('mousemove', (e) => {
            if (!mouse.isDragging) return;
            mouse.x = e.clientX;
            mouse.y = e.clientY;
        });

        window.addEventListener('mouseup', () => {
            mouse.isDragging = false;
        });

        //
        window.addEventListener('touchstart', (e) => {
            mouse.isDragging = true;
            mouse.x = e.touches[0].clientX;
            mouse.y = e.touches[0].clientY;
            mouse.px = e.touches[0].clientX;
            mouse.py = e.touches[0].clientY;
        });

        window.addEventListener('touchmove', (e) => {
            if (!mouse.isDragging) return;
            mouse.x = e.touches[0].clientX;
            mouse.y = e.touches[0].clientY;
        });

        window.addEventListener('touchend', () => {
            mouse.isDragging = false;
        });

        //
        init();
        animate();
    </script>
</body>

</html>
